{
  "manifest_version": 3,
  "name": "PhishGuard Explainable AI Scanner",
  "version": "1.0",
  "description": "Scans emails on Gmail and Outlook in real time using the local PhishGuard ML pipeline and explainable AI.",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "http://127.0.0.1:5000/*",
    "http://localhost:5000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://mail.google.com/*",
        "https://outlook.live.com/*",
        "https://outlook.office.com/*",
        "https://outlook.office365.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "PhishGuard Threat Audit"
  }
}
